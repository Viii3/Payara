check_move_error() {
    local exit_code="$1"
    local path="$2"
    local message="$3"

    if [ "$exit_code" -ne 0 ]; then
      local ignored_patterns=("mq" "h2db" "LICENSE.txt" "legal" "../legal" "osgi-cache")

      for pattern in "${ignored_patterns[@]}"; do
          if [[ "$path" == *"$pattern"* ]]; then
              echo "$message:$path"
              return 0
          fi
      done

      WARN=true
    fi
}

AS_INSTALL_PARENT=`dirname "$0"`
AS_INSTALL=`realpath --relative-to . $AS_INSTALL_PARENT/..`
echo "Server installation path: ${AS_INSTALL}"

case "`uname`" in
  CYGWIN*) AS_INSTALL=`cygpath --windows $AS_INSTALL`
esac

if [ -f "${AS_INSTALL}/config/upgrade-tool.properties" ]; then
    . "${AS_INSTALL}/config/upgrade-tool.properties"
else
    echo "${AS_INSTALL}/config/upgrade-tool.properties not present! This is unexpected: Exiting since this implies you haven't yet run the upgrade-server command or have cleared it"
    exit 1
fi

# Check current present
if [ ! -d "${AS_INSTALL}/modules" ]; then
    echo "No current install present! This is unexpected: Exiting since this implies you're running this script from a staged or old install"
    exit 1
fi

# Check staged present
if [ ! -d "${AS_INSTALL}/modules.new" ]; then
    echo "No staged install present! This is unexpected: Exiting since there's nothing to apply"
    exit 1
fi

# Check no old present
if [ -d "${AS_INSTALL}/modules.old" ]; then
    echo "Old install present! This is unexpected: Exiting since this script would overwrite the old install"
    exit 1
fi

for i in $(echo ${PAYARA_UPGRADE_DIRS} | sed "s/,/ /g")
do
    echo "Moving ${i} to old"
    if [ -d "${AS_INSTALL}/${i}" ]; then
        mv ${AS_INSTALL}/${i}/ ${AS_INSTALL}/${i}.old/
        check_move_error $? "${i}" "Ignoring error moving empty directory or file to old"
    else
        mv ${AS_INSTALL}/${i} ${AS_INSTALL}/${i}.old
        check_move_error $? "${i}" "Ignoring error moving empty directory or file to old"
    fi

    echo "Moving staged ${i} to expected location"
    if [ -d "${AS_INSTALL}/${i}.new" ]; then
        mv ${AS_INSTALL}/${i}.new ${AS_INSTALL}/${i}/
        check_move_error $? "${i}" "Ignoring error moving empty staged directory or file to expected location"
    else
        mv ${AS_INSTALL}/${i}.new ${AS_INSTALL}/${i}
        check_move_error $? "${i}" "Ignoring error moving empty staged directory or file to expected location"
    fi
done

if [ ! -z "$WARN" ]; then
    echo "A command didn't complete successfully! Check the logs and run the rollbackUpgrade script if desired. Skipping reinstallation of nodes, please run the reinstall-nodes ASadmin command if this is incorrect."
    exit 1
elif [ -d "${AS_INSTALL}/domains" ]; then
    exec ${AS_INSTALL}/bin/asadmin reinstall-nodes "$@"
    if [ ! $? -eq 0 ]; then
        WARN=true
    fi
else
    echo "Skipping reinstall-nodes due to no domains detected"
fi

if [ ! -z "$WARN" ]; then
    echo "A command didn't complete successfully! Check the logs and run the rollbackUpgrade script if desired."
    exit 1
else
    echo "The upgrade was applied successfully"
fi

